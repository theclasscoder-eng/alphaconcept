# =============================================================================
# Remote Desktop — example environment configuration.
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# All secrets below MUST be replaced with strong, randomly generated values.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# =============================================================================

# ---- Signaling service --------------------------------------------------------
# Postgres connection string used by Prisma in production.
DATABASE_URL=postgresql://rdp:rdp@localhost:5432/rdp?schema=public

# Port the Fastify signaling server listens on.
SIGNALING_PORT=8080

# Public URL/host the signaling server is reachable at (used in docs/logs, not secret).
SIGNALING_PUBLIC_URL=wss://signal.example.com

# Secret used to sign short-lived session JWTs issued after device authentication.
# Minimum 32 bytes of entropy. DO NOT reuse across environments.
JWT_SECRET=replace-me-with-a-long-random-secret

# Secret used to HMAC device authentication challenges (replay/tamper protection).
DEVICE_CHALLENGE_SECRET=replace-me-with-a-different-long-random-secret

# Data layer: "memory" (no external DB, for local dev/CI) or "prisma" (Postgres).
SIGNALING_STORE=memory

# Comma-separated list of allowed WebSocket Origin values ("*" disables the check —
# do NOT use "*" in production).
SIGNALING_ALLOWED_ORIGINS=*

# ---- STUN / TURN (NAT traversal) ---------------------------------------------
# STUN is unauthenticated and only reflects your public address.
STUN_URL=stun:stun.l.google.com:19302

# TURN relays media when direct connectivity fails.
TURN_URL=turn:turn.example.com:3478
TURN_HOST=turn.example.com
TURN_PORT=3478

# Shared secret configured in coturn (use-auth-secret). The signaling server derives
# time-limited TURN credentials from this. Coturn is configured with the SAME value.
TURN_SHARED_SECRET=replace-me-with-a-coturn-shared-secret

# Lifetime (seconds) of generated time-limited TURN credentials.
TURN_CREDENTIAL_TTL=3600

# ---- Runtime -----------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
