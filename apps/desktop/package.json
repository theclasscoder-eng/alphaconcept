{
  "name": "@rdp/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Windows-first secure remote desktop (host + controller) over WebRTC.",
  "author": "Remote Desktop",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "vitest run",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.0",
    "@rdp/config": "workspace:*",
    "@rdp/protocol": "workspace:*",
    "@rdp/shared": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^3.0.2",
    "zustand": "^5.0.3"
  }
}
