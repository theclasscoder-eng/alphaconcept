{
  "name": "AlphaConcept",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AlphaConcept — first attempt at the program",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @rdp/signaling db:migrate",
    "db:generate": "pnpm --filter @rdp/signaling db:generate",
    "dev": "pnpm --parallel --filter @rdp/signaling --filter @rdp/desktop dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  }
}
